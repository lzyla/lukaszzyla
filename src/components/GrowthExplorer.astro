---
// GrowthExplorer — interaktywna wizualizacja procentu składanego.
// Zero frameworka: to zwykły komponent Astro + <script> (Astro sam bundluje
// i uruchamia ten skrypt w przeglądarce). Wstawiasz go w MDX i działa w tekście.
//
// Props pozwalają ustawić wartości startowe per instancja.
interface Props {
  principal?: number;
  rate?: number;
  years?: number;
}
const { principal = 1000, rate = 7, years = 20 } = Astro.props;
// Unikalne id, żeby na jednej stronie mogło żyć kilka takich widgetów naraz.
const uid = 'ge-' + Math.random().toString(36).slice(2, 9);
---

<div class="growth-explorer" id={uid} data-principal={principal} data-rate={rate} data-years={years}>
  <div class="ge-controls">
    <label>
      <span>Wpłata początkowa: <b data-out="principal"></b> zł</span>
      <input type="range" name="principal" min="100" max="50000" step="100" value={principal} />
    </label>
    <label>
      <span>Roczna stopa zwrotu: <b data-out="rate"></b>%</span>
      <input type="range" name="rate" min="0" max="20" step="0.5" value={rate} />
    </label>
    <label>
      <span>Horyzont: <b data-out="years"></b> lat</span>
      <input type="range" name="years" min="1" max="40" step="1" value={years} />
    </label>
  </div>

  <svg class="ge-chart" viewBox="0 0 600 300" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Wykres wzrostu kapitału">
    <g class="ge-grid"></g>
    <path class="ge-area" />
    <path class="ge-line" />
  </svg>

  <p class="ge-result">
    Po <b data-out="years"></b> latach: <b data-out="final" class="ge-final"></b> zł
    <span class="muted">(wpłacone: <b data-out="principal2"></b> zł, zysk: <b data-out="profit"></b> zł)</span>
  </p>
</div>

<style>
  .growth-explorer {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.25rem 1rem;
    margin: 2rem 0;
    font-family: var(--font-sans);
    font-size: 0.95rem;
  }
  .ge-controls {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  @media (min-width: 34rem) {
    .ge-controls { grid-template-columns: repeat(3, 1fr); }
  }
  .growth-explorer label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--muted);
  }
  .growth-explorer label b { color: var(--fg); font-variant-numeric: tabular-nums; }
  .growth-explorer input[type="range"] { width: 100%; accent-color: var(--accent); }
  .ge-chart { width: 100%; height: auto; display: block; }
  .ge-line { fill: none; stroke: var(--accent); stroke-width: 2.5; }
  .ge-area { fill: var(--accent); opacity: 0.10; }
  .ge-grid line { stroke: var(--border); stroke-width: 1; }
  .ge-grid text { fill: var(--muted); font-size: 11px; font-family: var(--font-sans); }
  .ge-result { margin: 0.75rem 0 0; font-size: 0.95rem; }
  .ge-final { color: var(--accent); font-size: 1.15rem; }
  .ge-result .muted { display: block; font-size: 0.8rem; margin-top: 0.15rem; }
</style>

<script>
  function initGrowthExplorers() {
    const W = 600, H = 300, padL = 8, padR = 8, padT = 12, padB = 22;
    const fmt = new Intl.NumberFormat('pl-PL', { maximumFractionDigits: 0 });

    document.querySelectorAll<HTMLElement>('.growth-explorer').forEach((root) => {
      if (root.dataset.wired) return;
      root.dataset.wired = 'true';

      const inputs = root.querySelectorAll<HTMLInputElement>('input[type="range"]');
      const grid = root.querySelector<SVGGElement>('.ge-grid')!;
      const line = root.querySelector<SVGPathElement>('.ge-line')!;
      const area = root.querySelector<SVGPathElement>('.ge-area')!;

      const setOut = (key: string, val: string) =>
        root.querySelectorAll(`[data-out="${key}"]`).forEach((el) => (el.textContent = val));

      function render() {
        const vals: Record<string, number> = {};
        inputs.forEach((i) => (vals[i.name] = parseFloat(i.value)));
        const { principal, rate, years } = vals;

        // Miesięczne kapitalizowanie: V(t) = P * (1 + r/12)^(12t)
        const monthlyR = rate / 100 / 12;
        const months = Math.round(years * 12);
        const series: number[] = [];
        for (let m = 0; m <= months; m++) {
          series.push(principal * Math.pow(1 + monthlyR, m));
        }
        const maxV = Math.max(series[series.length - 1], principal * 1.001);
        const finalV = series[series.length - 1];

        // Skalowanie do obszaru wykresu.
        const x = (i: number) => padL + (i / months) * (W - padL - padR);
        const y = (v: number) => H - padB - (v / maxV) * (H - padT - padB);

        let d = '';
        series.forEach((v, i) => (d += (i === 0 ? 'M' : 'L') + x(i).toFixed(1) + ' ' + y(v).toFixed(1) + ' '));
        line.setAttribute('d', d.trim());
        area.setAttribute('d', `${d.trim()} L${x(months).toFixed(1)} ${H - padB} L${x(0).toFixed(1)} ${H - padB} Z`);

        // Siatka pozioma (3 linie) z podpisami wartości.
        grid.innerHTML = '';
        const ns = 'http://www.w3.org/2000/svg';
        for (let k = 1; k <= 3; k++) {
          const val = (maxV / 3) * k;
          const yy = y(val);
          const ln = document.createElementNS(ns, 'line');
          ln.setAttribute('x1', String(padL)); ln.setAttribute('x2', String(W - padR));
          ln.setAttribute('y1', yy.toFixed(1)); ln.setAttribute('y2', yy.toFixed(1));
          grid.appendChild(ln);
          const tx = document.createElementNS(ns, 'text');
          tx.setAttribute('x', String(padL)); tx.setAttribute('y', (yy - 4).toFixed(1));
          tx.textContent = fmt.format(val) + ' zł';
          grid.appendChild(tx);
        }

        setOut('principal', fmt.format(principal));
        setOut('principal2', fmt.format(principal));
        setOut('rate', String(rate));
        setOut('years', String(years));
        setOut('final', fmt.format(finalV));
        setOut('profit', fmt.format(finalV - principal));
      }

      inputs.forEach((i) => i.addEventListener('input', render));
      render();
    });
  }

  initGrowthExplorers();
  // Astro View Transitions (jeśli włączysz) — ponowne podpięcie po nawigacji.
  document.addEventListener('astro:page-load', initGrowthExplorers);
</script>
