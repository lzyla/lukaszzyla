---
import Site from '../layouts/Site.astro';
---

<Site title="Projects — Łukasz Żyła" current="projects">
  <section>
    <h1 class="sr-only">Projects</h1>
    <ul class="items">
      <li>
        <strong>#OtwartePaństwo</strong> — a civic-tech platform aggregating and
        standardizing scattered public-institution documents (official journals,
        BIPs) into one searchable, quotable source.
      </li>
      <li>
        <a href="https://ktorzadzi.pl" target="_blank" rel="noopener">ktorzadzi.pl&nbsp;↗</a>
        — a data-journalism app visualizing power networks between politics and
        business, backed by news from official government sources.
      </li>
      <li>
        <a href="https://jaturzadze.pl" target="_blank" rel="noopener">jaturzadze.pl&nbsp;↗</a>
        — an app processing and visualizing local-government financial data;
        award-winning prototype (3rd place at Poland's first public-data
        hackathon), later revisited in a 2025 MEN edition.
      </li>
      <li>
        <strong>Aplikacja Parlament / Sejm</strong> — the first app processing
        live data from the Polish Sejm — real-time parliamentary data as an
        accessible feed.
      </li>
      <li>
        <strong>Aplikacja Wojaczek</strong> — an audio-literary mobile app
        (“In Wojaczek's Footsteps”) blending cultural heritage, media production
        and location-based storytelling.
      </li>
    </ul>
  </section>
</Site>
