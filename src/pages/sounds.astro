---
import Site from '../layouts/Site.astro';
import GroupLabel from '../components/GroupLabel.astro';
---

<Site title="Sounds — Łukasz Żyła" current="sounds">
  <section>
    <h1 class="sr-only">Sounds</h1>
    <div class="prose">
      <p>
        As <em>złe oko</em> I build sound from computer programs (including
        machine learning), guitar, electronic transducers and field recordings.
        My setup includes guitar, a prepared radio, a laptop and neural-network
        models. I constantly archive audio recordings from my travels.
      </p>
      <p>
        My practice sits between field recording, improvisation and machine
        synthesis. I treat sound not as finished material but as a process —
        recorded, taken apart and reassembled beyond the usual measures of
        frequency, envelope and time.
      </p>
    </div>

    <figure class="figure">
      <div class="figure-media">
        <img src="/assets/lukasz.jpg" alt="Łukasz Żyła performing as złe oko in the Forest sound installation" loading="lazy" />
        <div class="skulls" id="skulls" aria-hidden="true"></div>
      </div>
      <figcaption>As złe oko — Forest, Przegędza near Rybnik, 2025</figcaption>
    </figure>

    <div class="groups">
      <div>
        <GroupLabel>Forest</GroupLabel>
        <p class="item">
          An immersive sound concert in the woods — Kanetowiec clearing,
          Przegędza near Rybnik (18 October 2025). Instead of instruments:
          rustling leaves, the breath of open space and animal echoes, captured
          live and reworked into a layered soundscape spread across speakers
          arranged in a circle around the audience. Some sounds come from nature;
          others are recreated by a neural network (VAE) — a bioacoustic
          reconstruction and resynthesis of a place that has lost its own sound.
          No stage, no divide between performers and listeners: a circle of
          people listening, often with their eyes closed. With Emiter (Marcin
          Dymiter) and Izabela Dłużyk.
        </p>
      </div>
      <div>
        <GroupLabel>Film</GroupLabel>
        <p class="item">
          Live scores performed to film, responding to the image in real time —
          including the surrealist films of Jan Švankmajer and Tetsuo: The Iron
          Man (Shinya Tsukamoto) in a noise / industrial register.
        </p>
      </div>
      <div>
        <GroupLabel>Poetry</GroupLabel>
        <p class="item">
          Live sound for poetry readings — in dialogue with the words, shaping
          the breath and rhythm of the reading. With poets Peter Waugh, Hanane
          Aad, Krzysztof Siwczyk, Robert Rybicki, Arkadiusz Kremza, Maciej
          Melecki and Ylorybaz.
        </p>
      </div>
    </div>
  </section>
</Site>

<style is:global>
  .figure-media { position: relative; overflow: hidden; line-height: 0; }
  .skulls { position: absolute; inset: 0; pointer-events: none; }
  .skulls .sk { position: absolute; opacity: 0; }
  .skulls .sk svg { display: block; width: 100%; height: 100%; }
  @keyframes skFlicker {
    0%, 100% { opacity: 0; }
    12% { opacity: var(--pk, 0.4); }
    22% { opacity: calc(var(--pk, 0.4) * 0.25); }
    38% { opacity: var(--pk, 0.4); }
    55% { opacity: calc(var(--pk, 0.4) * 0.5); }
    72% { opacity: var(--pk, 0.4); }
    88% { opacity: calc(var(--pk, 0.4) * 0.2); }
  }
  @media (prefers-reduced-motion: reduce) {
    .skulls { display: none; }
  }
</style>

<script>
  const layer = document.getElementById('skulls');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (layer && !reduce) {
    const SVG =
      '<svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">' +
      '<path d="M10 1.6c-3.6 0-6 2.6-6 6 0 2 .9 3.2 1.7 4 .3.3.5.7.5 1.1v1.1c0 .5.4.9.9.9h.3v-1.6h1v1.6h1v-1.6h1v1.6h.3c.5 0 .9-.4.9-.9v-1.1c0-.4.2-.8.5-1.1.8-.8 1.7-2 1.7-4 0-3.4-2.4-6-6-6z" fill="#f4f2ee"/>' +
      '<circle cx="7.4" cy="8" r="1.5" fill="#171512"/><circle cx="12.6" cy="8" r="1.5" fill="#171512"/>' +
      '<path d="M10 10.2l-.9 1.7h1.8z" fill="#171512"/></svg>';
    // Losowa pozycja tylko na ścianach (pomija postać/krzesło w centrum-dole i podłogę)
    const wallPos = () => {
      for (let i = 0; i < 10; i++) {
        const rx = Math.random();
        const ry = 0.04 + Math.random() * 0.60;
        if (rx > 0.36 && rx < 0.64 && ry > 0.38) continue;
        return [rx, ry];
      }
      return [Math.random(), 0.05 + Math.random() * 0.28];
    };
    const spawn = () => {
      const w = layer.clientWidth, h = layer.clientHeight;
      if (!w || !h || layer.childElementCount > 30) return;
      const el = document.createElement('div');
      el.className = 'sk';
      const size = 9 + Math.random() * 9;
      const [rx, ry] = wallPos();
      el.style.width = size + 'px';
      el.style.height = size + 'px';
      el.style.left = rx * (w - size) + 'px';
      el.style.top = ry * (h - size) + 'px';
      const peak = 0.28 + Math.random() * 0.22;
      el.style.setProperty('--pk', peak.toFixed(2));
      const dur = 0.5 + Math.random() * 3.0;
      el.style.animation = 'skFlicker ' + dur.toFixed(2) + 's linear forwards';
      el.innerHTML = SVG;
      layer.appendChild(el);
      setTimeout(() => el.remove(), dur * 1000 + 60);
    };
    const loop = () => {
      spawn();
      if (Math.random() < 0.6) spawn();
      if (Math.random() < 0.3) spawn();
      setTimeout(loop, 130 + Math.random() * 360);
    };
    loop();
  }
</script>
