---
import Site from '../layouts/Site.astro';
import GroupLabel from '../components/GroupLabel.astro';
---

<Site title="Publications — Łukasz Żyła" current="publications">
  <section>
    <h1 class="sr-only">Publications</h1>
    <div class="groups">
      <div>
        <GroupLabel>Book — author</GroupLabel>
        <p class="item">
          <strong>Dziennikarstwo danych i data storytelling</strong>
          [Data Journalism and Data Storytelling] — a theoretical–practical book,
          Helion, 2022. The first Polish book on data journalism.
        </p>
      </div>
      <div>
        <GroupLabel>Academic</GroupLabel>
        <ul class="items items--tight">
          <li>
            “Cyfrowy dostęp do informacji i danych o funkcjonowaniu państwa a
            prawo do informacji jako prawo człowieka” [Digital access to
            information and data on the functioning of the state, and the right to
            information as a human right] — chapter in the monograph
            <em>Otwarte dane i ich ponowne wykorzystywanie w prawie polskim</em>
            [Open Data and Its Re-use in Polish Law], ed. Prof. M. Bernaczyk,
            University of Wrocław Press, 2021.
          </li>
          <li>
            “Elektroniczne udostępnianie informacji a prawa człowieka”
            [Electronic disclosure of information and human rights] — European
            Review of Law and International Relations, No. 4(51), 2019.
          </li>
        </ul>
      </div>
      <div>
        <GroupLabel>Industry</GroupLabel>
        <p class="item">
          “Formaty i opowieści oparte na danych” [Data-driven formats and
          stories] — EBIB Bulletin, No. 200, 2021.
        </p>
      </div>
      <div>
        <GroupLabel>Translation — book</GroupLabel>
        <p class="item">
          <em>Psychomagic</em> by Alejandro Jodorowsky — translation from
          Spanish, Okultura, 2012.
        </p>
      </div>
      <div>
        <GroupLabel>Journalism / blogs</GroupLabel>
        <p class="item">
          <a href="https://datablog.pl" target="_blank" rel="noopener">datablog.pl&nbsp;↗</a>
          — the first data-journalism blog in Poland.
        </p>
      </div>
    </div>
  </section>
</Site>
