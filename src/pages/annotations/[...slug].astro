---
import { getCollection, render } from 'astro:content';
import Annotation from '../../layouts/Annotation.astro';

export async function getStaticPaths() {
  const posts = await getCollection('annotations', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Annotation title={post.data.title} description={post.data.description} date={post.data.date}>
  <Content />
</Annotation>
