---
import Site from '../layouts/Site.astro';
import GroupLabel from '../components/GroupLabel.astro';
---

<Site title="Workshops — Łukasz Żyła" current="workshops">
  <section>
    <h1 class="sr-only">Workshops</h1>
    <div class="groups">
      <div>
        <GroupLabel>Academic teaching</GroupLabel>
        <ul class="items items--tight">
          <li>Lecturer at AGH University of Science and Technology, Social Informatics programme (2022–present) — courses including “Social Startups” and “Data Storytelling”.</li>
          <li>Coordinator of the Data Storytelling postgraduate programme (AGH).</li>
          <li>Author of course syllabi: “Access to Digital Information” and “Legal Aspects of Data Processing”.</li>
        </ul>
      </div>
      <div>
        <GroupLabel>Business &amp; public administration</GroupLabel>
        <ul class="items items--tight">
          <li>Coordinator of training in the “Przestrzeń from Facebook” programme — in partnership with Facebook and Freeformers; trained 800+ people (aged 18–25) in digital skills and task automation.</li>
          <li>Training on automation and APIs for open-data officers across all ministries and central government offices.</li>
          <li>Digital-skills and AI training for Humanitas University, the Jagiellonian University, the University of Wrocław and the Silesian University of Technology.</li>
          <li>Training sessions and talks for Facebook and SAP; workshops on prototyping apps that solve social problems (Facebook).</li>
        </ul>
      </div>
      <div>
        <GroupLabel>Law — new technologies &amp; access to information</GroupLabel>
        <ul class="items items--tight">
          <li>Training on new-technology law for student research groups at the Jagiellonian University, the University of Wrocław and the Pedagogical University in Kraków.</li>
          <li>Training on the right to information for the Diplomatic Academy (Polish MFA).</li>
        </ul>
      </div>
      <div>
        <GroupLabel>Media &amp; journalists</GroupLabel>
        <ul class="items items--tight">
          <li>Trained journalists from Gazeta Wyborcza, Polska Press, Axel Springer, Wirtualna Polska and Newsweek (2015).</li>
          <li>Training for local media (Silesia region, 2017).</li>
          <li>Data-visualization and content-creation training for the Polish MFA (information department, 2015).</li>
          <li>Ran Media Labs 3.0 (Gliwice) — new-media workshops for journalists.</li>
          <li>New-media workshops for the Information Society Development Foundation (FRSI); ICT training across southern Poland.</li>
        </ul>
      </div>
      <div>
        <GroupLabel>Youth education &amp; creative coding</GroupLabel>
        <ul class="items items--tight">
          <li>Founder and coordinator of the Hack Heroes contest (EU Code Week; partners: Ministry of Digital Affairs, GovTech, SAP Poland, HP Inc).</li>
          <li>Workshops on programming, electronics and creative coding (e.g. Warsztat Miejski / Urban Workshop).</li>
        </ul>
      </div>
      <div>
        <GroupLabel>Conference &amp; event organization</GroupLabel>
        <ul class="items items--tight">
          <li>Organizer of Databeers — the first data-focused conference in Poland (part of the international Databeers format).</li>
          <li>Organizer of Data 3.0 in Warsaw — an event dedicated to data and new media.</li>
          <li>Organizer of Poland's first new-technology workshops and conferences for journalists.</li>
        </ul>
      </div>
    </div>
  </section>
</Site>
