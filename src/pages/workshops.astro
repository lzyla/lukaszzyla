---
import Site from '../layouts/Site.astro';
import GroupLabel from '../components/GroupLabel.astro';
---

<Site title="Workshops — Łukasz Żyła" current="workshops">
  <section>
    <h1 class="sr-only">Workshops</h1>
    <div class="groups">
      <div>
        <GroupLabel>Academic teaching</GroupLabel>
        <ul class="items items--tight">
          <li>I lecture at AGH University of Science and Technology, in the Social Informatics programme (2022–present) — teaching courses including “Social Startups” and “Data Storytelling”.</li>
          <li>I coordinate the Data Storytelling postgraduate programme (AGH).</li>
          <li>I wrote the course syllabi “Access to Digital Information” and “Legal Aspects of Data Processing”.</li>
        </ul>
      </div>
      <div>
        <GroupLabel>Business &amp; public administration</GroupLabel>
        <ul class="items items--tight">
          <li>I coordinated training in the “Przestrzeń from Facebook” programme — in partnership with Facebook and Freeformers — training 800+ people (aged 18–25) in digital skills and task automation.</li>
          <li>I ran training on automation and APIs for open-data officers across all ministries and central government offices.</li>
          <li>I taught digital-skills and AI courses for Humanitas University, the Jagiellonian University, the University of Wrocław and the Silesian University of Technology.</li>
          <li>I ran sessions and talks for Facebook and SAP, including workshops on prototyping apps that solve social problems (Facebook).</li>
        </ul>
      </div>
      <div>
        <GroupLabel>Law — new technologies &amp; access to information</GroupLabel>
        <ul class="items items--tight">
          <li>I taught new-technology law to student research groups at the Jagiellonian University, the University of Wrocław and the Pedagogical University in Kraków.</li>
          <li>I ran right-to-information training for the Diplomatic Academy (Polish MFA).</li>
        </ul>
      </div>
      <div>
        <GroupLabel>Media &amp; journalists</GroupLabel>
        <ul class="items items--tight">
          <li>I trained journalists from Gazeta Wyborcza, Polska Press, Axel Springer, Wirtualna Polska and Newsweek (2015).</li>
          <li>I ran training for local media (Silesia region, 2017).</li>
          <li>I taught data-visualization and content-creation for the Polish MFA (information department, 2015).</li>
          <li>I ran Media Labs 3.0 (Gliwice) — new-media workshops for journalists.</li>
          <li>I led new-media workshops for the Information Society Development Foundation (FRSI), with ICT training across southern Poland.</li>
        </ul>
      </div>
      <div>
        <GroupLabel>Youth education &amp; creative coding</GroupLabel>
        <ul class="items items--tight">
          <li>I founded and coordinated the Hack Heroes contest (EU Code Week; partners: Ministry of Digital Affairs, GovTech, SAP Poland, HP Inc).</li>
          <li>I ran workshops on programming, electronics and creative coding (e.g. Warsztat Miejski / Urban Workshop).</li>
        </ul>
      </div>
      <div>
        <GroupLabel>Conference &amp; event organization</GroupLabel>
        <ul class="items items--tight">
          <li>I organized Databeers — the first data-focused conference in Poland (part of the international Databeers format).</li>
          <li>I organized Data 3.0 in Warsaw — an event dedicated to data and new media.</li>
          <li>I organized Poland's first new-technology workshops and conferences for journalists.</li>
        </ul>
      </div>
    </div>
  </section>
</Site>
