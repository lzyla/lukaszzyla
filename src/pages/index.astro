---
import Site from '../layouts/Site.astro';
---

<Site title="Łukasz Żyła">
  <div class="intro-block">
    <img
      class="portrait"
      src="/assets/lukasz-portrait.jpg"
      alt="Łukasz Żyła"
      width="220"
      height="300"
      loading="eager"
    />
    <div class="lede">
      <p>
        Hi! I'm a lawyer, researcher and open-data specialist working where
        data, journalism, law and AI meet. I wrote the first Polish book on data
        journalism — <a href="/publications/">Data Journalism and Data Storytelling</a>
        — and I've taught at the University of Wrocław, the Jagiellonian University
        and in the Social Informatics programme at
        <a href="https://informatyka-spoleczna.agh.edu.pl" target="_blank" rel="noopener">AGH University of Science and Technology&nbsp;↗</a>.
        I also contributed to work on open-data standards at the Polish Ministry of
        Digital Affairs.
      </p>
      <p>
        These days I focus on voice interfaces at
        <a href="https://vocative.ai" target="_blank" rel="noopener">Vocative.ai&nbsp;↗</a>
        and on neural audio synthesis from field recordings — which also feeds my
        ambient work as <em>złe oko</em>.
      </p>
    </div>
  </div>
</Site>

<style>
  .intro-block {
    display: flex;
    flex-direction: row-reverse;
    align-items: flex-start;
    gap: 34px;
  }
  .portrait {
    flex: 0 0 auto;
    width: 220px;
    height: 300px;
    object-fit: cover;
    object-position: center 28%;
    filter: grayscale(1) contrast(1.05) brightness(0.98);
    transition: filter 0.3s ease, transform 0.3s ease;
  }
  .portrait:hover {
    filter: grayscale(1) contrast(1.08) brightness(1.03);
    transform: translateY(-2px);
  }
  .intro-block .lede { flex: 1 1 auto; min-width: 0; }

  @media (max-width: 768px) {
    .intro-block {
      flex-direction: column-reverse;
      align-items: flex-start;
      gap: 26px;
    }
    .portrait { width: 200px; height: 270px; }
  }
</style>
