---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Łukasz — pisanie, projekty, research">
  <header>
    <h1>Cześć, tu Łukasz.</h1>
    <p class="muted">
      Prawo, AI i media. Piszę notatki i buduję małe interaktywne rzeczy.
      Poniżej to, nad czym ostatnio pracowałem.
    </p>
  </header>

  <h2>Pisanie</h2>
  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <a href={`/writing/${post.id}/`}>{post.data.title}</a>
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('pl-PL', { year: 'numeric', month: 'short', day: 'numeric' })}
        </time>
      </li>
    ))}
  </ul>
</Base>
