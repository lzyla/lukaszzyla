---
import Card from './Card.astro';

interface Props {
  title: string;
  description?: string;
  current?: string; // klucz aktywnej pozycji nav: annotations | projects | sounds | publications | workshops | bio
}
const { title, description, current } = Astro.props;

const nav = [
  { key: 'annotations', n: 1, label: 'Annotations', href: '/annotations/' },
  { key: 'projects', n: 2, label: 'Projects', href: '/projects/' },
  { key: 'publications', n: 3, label: 'Publications', href: '/publications/' },
  { key: 'workshops', n: 4, label: 'Workshops', href: '/workshops/' },
  { key: 'sounds', n: 5, label: 'Sounds', href: '/sounds/' },
  { key: 'bio', n: 6, label: 'Bio', href: '/bio/' },
];

// Codrops LineHoverStyles #14 ("carme") — odręczne, rysujące się podkreślenie.
const scribble =
  '<svg class="scribble" viewBox="0 0 101 9" preserveAspectRatio="none" aria-hidden="true"><path pathLength="1" vector-effect="non-scaling-stroke" d="M.426 1.973C4.144 1.567 17.77-.514 21.443 1.48 24.296 3.026 24.844 4.627 27.5 7c3.075 2.748 6.642-4.141 10.066-4.688 7.517-1.2 13.237 5.425 17.59 2.745C58.5 3 60.464-1.786 66 2c1.996 1.365 3.174 3.737 5.286 4.41 5.423 1.727 25.34-7.981 29.14-1.294"/></svg>';
---

<Card title={title} description={description}>
  <main class="card">
    <header class="masthead">
      <a class="name" href="/">Łukasz Żyła<Fragment set:html={scribble} /></a>
      <nav class="nav" aria-label="Sections">
        {nav.map((item) => (
          <a href={item.href} aria-current={current === item.key ? 'page' : undefined}>
            {item.n}&nbsp;{item.label}<Fragment set:html={scribble} />
          </a>
        ))}
      </nav>
    </header>

    <slot />

    <hr class="rule rule--contact" />
    <p class="contact">
      Reach out: <a href="mailto:hello@lukaszzyla.com">hello@lukaszzyla.com</a>.
    </p>
  </main>
</Card>
