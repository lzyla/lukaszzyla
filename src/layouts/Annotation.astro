---
import Site from './Site.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
}
const { title, description, date } = Astro.props;
const formatted = date.toLocaleDateString('en-GB', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<Site title={`${title} — Łukasz Żyła`} description={description} current="annotations">
  <article class="anno">
    <h1 class="anno-title">{title}</h1>
    <p class="anno-meta"><time datetime={date.toISOString()}>{formatted}</time></p>
    <div class="prose anno-body">
      <slot />
    </div>
  </article>
  <hr class="rule" style="margin-top:48px" />
  <p class="contact"><a href="/annotations/">← All annotations</a></p>
</Site>

<style is:global>
  .anno-title {
    font-size: 34px;
    font-weight: 500;
    line-height: 1.2;
    color: var(--ink);
    margin: 0 0 10px;
  }
  .anno-meta {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--muted);
    margin: 0 0 36px;
  }
  .anno-body h2 {
    font-size: 24px;
    font-weight: 500;
    color: var(--ink);
    margin: 40px 0 14px;
    line-height: 1.3;
  }
  .anno-body h3 {
    font-size: 20px;
    font-weight: 500;
    color: var(--ink);
    margin: 30px 0 10px;
  }
  .anno-body ul,
  .anno-body ol {
    margin: 0 0 18px;
    padding-left: 1.3em;
  }
  .anno-body li { margin: 0 0 8px; }
  .anno-body blockquote {
    margin: 0 0 18px;
    padding-left: 18px;
    border-left: 2px solid var(--rule);
    color: var(--label);
    font-style: italic;
  }
  .anno-body code {
    font-family: var(--font-mono);
    font-size: 0.86em;
    background: rgba(27, 24, 21, 0.05);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }
  .anno-body pre {
    overflow-x: auto;
    padding: 16px 18px;
    border-radius: 6px;
    font-size: 14px;
    line-height: 1.5;
  }
  .anno-body pre code { background: none; padding: 0; }
</style>
